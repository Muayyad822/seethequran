{
  "surahNumber": 81,
  "surahName": "At-Takwir",
  "scenes": [
    { "verseNumber": 1, "verseKey": "81:1", "emotion": "cosmic", "atmosphere": "void", "visualElements": ["sun_dimming", "solar_collapse"], "backgroundGradient": ["#000000", "#1a1000"], "particleConfig": { "type": "embers", "count": 100, "color": "#ff8c00", "speed": "slow", "direction": "inward" }, "motionType": "collapse", "ambientColor": "#0a0a00", "glowColor": "#ff8c00", "transitionDuration": 2000, "reflectionPrompt": "When the sun is folded up, where will you find your light?", "tafsirHighlight": "The sun will be wrapped up, its light extinguished and its existence brought to an end." },
    { "verseNumber": 2, "verseKey": "81:2", "emotion": "cosmic", "atmosphere": "void", "visualElements": ["stars_falling", "void_streaks"], "backgroundGradient": ["#000000", "#00002a"], "particleConfig": { "type": "stars", "count": 200, "color": "#ffffff", "speed": "fast", "direction": "downward" }, "motionType": "fall", "ambientColor": "#00001a", "glowColor": "#ffffff", "transitionDuration": 1500, "reflectionPrompt": "If the stars lose their place, what is truly fixed in your life?", "tafsirHighlight": "The stars will fall and be scattered, losing their brilliance and order." },
    { "verseNumber": 3, "verseKey": "81:3", "emotion": "cosmic", "atmosphere": "chaotic", "visualElements": ["mountains_crumbling", "dust_clouds"], "backgroundGradient": ["#000000", "#2a1a1a"], "particleConfig": { "type": "dust", "count": 150, "color": "#8b4513", "speed": "medium", "direction": "upward" }, "motionType": "tremor", "ambientColor": "#1a0a0a", "glowColor": "#8b4513", "transitionDuration": 1200, "reflectionPrompt": "The firmest things we know will vanish. What remains?", "tafsirHighlight": "Mountains will be moved from their places and turned into dust, vanishing like a mirage." },
    { "verseNumber": 4, "verseKey": "81:4", "emotion": "solemn", "atmosphere": "abandoned", "visualElements": ["desert_haze", "neglected_figures"], "backgroundGradient": ["#1a1000", "#0a0a0a"], "particleConfig": { "type": "sand", "count": 50, "color": "#c9a84c", "speed": "slow", "direction": "horizontal" }, "motionType": "drift", "ambientColor": "#0a0a0a", "glowColor": "#c9a84c", "transitionDuration": 2500, "reflectionPrompt": "What prized possessions will you leave behind?", "tafsirHighlight": "Even the most valuable assets, like ten-month pregnant camels (prized by Arabs), will be neglected in the chaos." },
    { "verseNumber": 5, "verseKey": "81:5", "emotion": "dread", "atmosphere": "primal", "visualElements": ["wild_eyes", "shadowy_forms"], "backgroundGradient": ["#0a0a0a", "#1a0a00"], "particleConfig": { "type": "shadows", "count": 30, "color": "#000000", "speed": "agitated", "direction": "random" }, "motionType": "agitate", "ambientColor": "#050505", "glowColor": "#ff4500", "transitionDuration": 1000, "reflectionPrompt": "In the ultimate gathering, where will you stand?", "tafsirHighlight": "Wild beasts will be gathered together, losing their natural fear of one another in the terror of the Day." },
    { "verseNumber": 6, "verseKey": "81:6", "emotion": "warning", "atmosphere": "inferno", "visualElements": ["boiling_waves", "steam_clouds"], "backgroundGradient": ["#00002a", "#3d0000"], "particleConfig": { "type": "steam", "count": 120, "color": "#ff4500", "speed": "fast", "direction": "upward" }, "motionType": "surge", "ambientColor": "#1a0000", "glowColor": "#ff0000", "transitionDuration": 1800, "reflectionPrompt": "Can the oceans hold back the fire of that Day?", "tafsirHighlight": "The seas will be set on fire or overflow, turning into a vast, boiling inferno." },
    { "verseNumber": 7, "verseKey": "81:7", "emotion": "solemn", "atmosphere": "gathering", "visualElements": ["soul_pairs", "light_merging"], "backgroundGradient": ["#0a0a0a", "#1a1a2e"], "particleConfig": { "type": "orbs", "count": 80, "color": "#ffffff", "speed": "slow", "direction": "merge" }, "motionType": "merge", "ambientColor": "#000000", "glowColor": "#ffffff", "transitionDuration": 2200, "reflectionPrompt": "Who would you want to be grouped with on that Day?", "tafsirHighlight": "Souls will be joined with their like — the righteous with the righteous, and the wicked with the wicked." },
    { "verseNumber": 8, "verseKey": "81:8", "emotion": "dread", "atmosphere": "judgment", "visualElements": ["silent_echo", "deep_void"], "backgroundGradient": ["#000000", "#1a0000"], "particleConfig": { "type": "echo", "count": 20, "color": "#ff0000", "speed": "very_slow", "direction": "outward" }, "motionType": "still", "ambientColor": "#050000", "glowColor": "#ff0000", "transitionDuration": 3000, "reflectionPrompt": "What innocent voice will cry out for justice?", "tafsirHighlight": "The girl-child buried alive will be asked why she was killed — a profound indictment of injustice." },
    { "verseNumber": 9, "verseKey": "81:9", "emotion": "dread", "atmosphere": "judgment", "visualElements": ["silent_echo", "deep_void"], "backgroundGradient": ["#1a0000", "#000000"], "particleConfig": { "type": "echo", "count": 20, "color": "#ff0000", "speed": "very_slow", "direction": "outward" }, "motionType": "still", "ambientColor": "#050000", "glowColor": "#ff0000", "transitionDuration": 3000, "reflectionPrompt": "Every hidden wrong will be questioned. Are you ready?", "tafsirHighlight": "She will be asked for what sin she was killed, exposing the guilt of those who committed the act." },
    { "verseNumber": 10, "verseKey": "81:10", "emotion": "solemn", "atmosphere": "judgment", "visualElements": ["scrolls_unrolling", "white_pages"], "backgroundGradient": ["#0a0a0a", "#ffffff"], "particleConfig": { "type": "pages", "count": 60, "color": "#ffffff", "speed": "slow", "direction": "scatter" }, "motionType": "unroll", "ambientColor": "#1a1a1a", "glowColor": "#ffffff", "transitionDuration": 2000, "reflectionPrompt": "What will your 'page' say when it is opened?", "tafsirHighlight": "Records of deeds will be laid open for all to see, revealing every secret action." },
    { "verseNumber": 11, "verseKey": "81:11", "emotion": "cosmic", "atmosphere": "void", "visualElements": ["sky_peeling", "cosmic_exposure"], "backgroundGradient": ["#00002a", "#000000"], "particleConfig": { "type": "sky_shards", "count": 40, "color": "#4488ff", "speed": "slow", "direction": "outward" }, "motionType": "peel", "ambientColor": "#00001a", "glowColor": "#4488ff", "transitionDuration": 2500, "reflectionPrompt": "When the sky is stripped away, what truth remains?", "tafsirHighlight": "The sky will be stripped away like a skin, revealing what lies beyond." },
    { "verseNumber": 12, "verseKey": "81:12", "emotion": "warning", "atmosphere": "inferno", "visualElements": ["intense_flame", "heat_haze"], "backgroundGradient": ["#000000", "#3d0000"], "particleConfig": { "type": "fire", "count": 200, "color": "#ff4500", "speed": "fast", "direction": "upward" }, "motionType": "surge", "ambientColor": "#1a0000", "glowColor": "#ff0000", "transitionDuration": 1500, "reflectionPrompt": "A fire kindled by deeds. How do we extinguish it?", "tafsirHighlight": "Hellfire will be set ablaze with intense heat, ready for its inhabitants." },
    { "verseNumber": 13, "verseKey": "81:13", "emotion": "hope", "atmosphere": "divine", "visualElements": ["lush_light", "garden_glow"], "backgroundGradient": ["#000000", "#002a00"], "particleConfig": { "type": "petals", "count": 50, "color": "#00ff00", "speed": "slow", "direction": "downward" }, "motionType": "bloom", "ambientColor": "#001a00", "glowColor": "#00ff00", "transitionDuration": 2000, "reflectionPrompt": "Paradise is brought near. Are you moving toward it?", "tafsirHighlight": "Paradise will be brought near to the righteous, welcoming them to eternal peace." },
    { "verseNumber": 14, "verseKey": "81:14", "emotion": "solemn", "atmosphere": "judgment", "visualElements": ["focus_pulse", "soul_silhouette"], "backgroundGradient": ["#0a0a0a", "#c9a84c"], "particleConfig": { "type": "pulse", "count": 1, "color": "#c9a84c", "speed": "slow", "direction": "center" }, "motionType": "focus", "ambientColor": "#000000", "glowColor": "#c9a84c", "transitionDuration": 3000, "reflectionPrompt": "In this moment, what have you prepared?", "tafsirHighlight": "Every soul will then know exactly what it has brought of good or evil." },
    { "verseNumber": 15, "verseKey": "81:15", "emotion": "cosmic", "atmosphere": "night", "visualElements": ["receding_stars", "night_sky"], "backgroundGradient": ["#050508", "#1a1a2e"], "particleConfig": { "type": "stars", "count": 100, "color": "#ffffff", "speed": "very_slow", "direction": "circular" }, "motionType": "drift", "ambientColor": "#0d0d14", "glowColor": "#ffffff", "transitionDuration": 4000, "reflectionPrompt": "What is the wisdom in the stars that recede?", "tafsirHighlight": "An oath by the stars that recede and hide during the day." },
    { "verseNumber": 16, "verseKey": "81:16", "emotion": "cosmic", "atmosphere": "night", "visualElements": ["moving_stars", "celestial_paths"], "backgroundGradient": ["#1a1a2e", "#050508"], "particleConfig": { "type": "stars", "count": 100, "color": "#ffffff", "speed": "slow", "direction": "forward" }, "motionType": "drift", "ambientColor": "#0d0d14", "glowColor": "#ffffff", "transitionDuration": 4000, "reflectionPrompt": "The universe follows a perfect path. Do you?", "tafsirHighlight": "The stars that run their courses and then set." },
    { "verseNumber": 17, "verseKey": "81:17", "emotion": "solemn", "atmosphere": "night", "visualElements": ["deep_shadows", "night_descending"], "backgroundGradient": ["#050508", "#000000"], "particleConfig": { "type": "mist", "count": 40, "color": "#1a1a2e", "speed": "very_slow", "direction": "downward" }, "motionType": "fade", "ambientColor": "#000000", "glowColor": "#1a1a2e", "transitionDuration": 5000, "reflectionPrompt": "When the night departs, what remains in your heart?", "tafsirHighlight": "By the night as it departs or approaches." },
    { "verseNumber": 18, "verseKey": "81:18", "emotion": "hope", "atmosphere": "dawn", "visualElements": ["first_light", "morning_mist"], "backgroundGradient": ["#000000", "#1a1a2e", "#c9a84c"], "particleConfig": { "type": "light_rays", "count": 60, "color": "#f0ead6", "speed": "slow", "direction": "upward" }, "motionType": "breathe", "ambientColor": "#1a1a2e", "glowColor": "#c9a84c", "transitionDuration": 5000, "reflectionPrompt": "As the dawn breathes, can you feel your soul awaken?", "tafsirHighlight": "By the dawn as it breathes, bringing light and life to the world." },
    { "verseNumber": 19, "verseKey": "81:19", "emotion": "awe", "atmosphere": "divine", "visualElements": ["angelic_silhouette", "divine_radiance"], "backgroundGradient": ["#c9a84c", "#ffffff"], "particleConfig": { "type": "gold_dust", "count": 100, "color": "#c9a84c", "speed": "slow", "direction": "downward" }, "motionType": "descend", "ambientColor": "#f0ead6", "glowColor": "#c9a84c", "transitionDuration": 3000, "reflectionPrompt": "Who are the messengers in your life?", "tafsirHighlight": "Truly, this Quran is the word of a noble Messenger (Gabriel)." },
    { "verseNumber": 20, "verseKey": "81:20", "emotion": "awe", "atmosphere": "divine", "visualElements": ["throne_glow", "immense_power"], "backgroundGradient": ["#ffffff", "#c9a84c"], "particleConfig": { "type": "energy_waves", "count": 10, "color": "#c9a84c", "speed": "slow", "direction": "outward" }, "motionType": "pulse", "ambientColor": "#c9a84c", "glowColor": "#ffffff", "transitionDuration": 3000, "reflectionPrompt": "Power combined with trust. Is that your ideal?", "tafsirHighlight": "Possessed of great power, held in high honor with the Lord of the Throne." },
    { "verseNumber": 21, "verseKey": "81:21", "emotion": "awe", "atmosphere": "divine", "visualElements": ["divine_order", "trust_glow"], "backgroundGradient": ["#c9a84c", "#f0ead6"], "particleConfig": { "type": "still_light", "count": 50, "color": "#ffffff", "speed": "very_slow", "direction": "center" }, "motionType": "still", "ambientColor": "#f0ead6", "glowColor": "#c9a84c", "transitionDuration": 3000, "reflectionPrompt": "To be trusted by the Divine. What an honor.", "tafsirHighlight": "Obeyed there (in the heavens) and entirely trustworthy." },
    { "verseNumber": 22, "verseKey": "81:22", "emotion": "solemn", "atmosphere": "clarity", "visualElements": ["human_silhouette", "clear_light"], "backgroundGradient": ["#f0ead6", "#ffffff"], "particleConfig": { "type": "clarity", "count": 30, "color": "#000000", "speed": "slow", "direction": "focus" }, "motionType": "still", "ambientColor": "#ffffff", "glowColor": "#000000", "transitionDuration": 2000, "reflectionPrompt": "Is your path clear, or do you doubt the messenger?", "tafsirHighlight": "And your companion (Muhammad) is not mad." },
    { "verseNumber": 23, "verseKey": "81:23", "emotion": "awe", "atmosphere": "horizon", "visualElements": ["vast_horizon", "angelic_vision"], "backgroundGradient": ["#ffffff", "#4488ff", "#00002a"], "particleConfig": { "type": "vision_shards", "count": 40, "color": "#ffffff", "speed": "slow", "direction": "forward" }, "motionType": "expand", "ambientColor": "#4488ff", "glowColor": "#ffffff", "transitionDuration": 4000, "reflectionPrompt": "Have you seen the signs on the clear horizon?", "tafsirHighlight": "He surely saw him (Gabriel) on the clear horizon." },
    { "verseNumber": 24, "verseKey": "81:24", "emotion": "solemn", "atmosphere": "clarity", "visualElements": ["gift_glow", "open_hands"], "backgroundGradient": ["#00002a", "#1a1a2e"], "particleConfig": { "type": "knowledge_drops", "count": 20, "color": "#c9a84c", "speed": "slow", "direction": "downward" }, "motionType": "descend", "ambientColor": "#1a1a2e", "glowColor": "#c9a84c", "transitionDuration": 3000, "reflectionPrompt": "The Truth is shared freely. Do you accept it?", "tafsirHighlight": "And he does not withhold the knowledge of the Unseen." },
    { "verseNumber": 25, "verseKey": "81:25", "emotion": "solemn", "atmosphere": "protection", "visualElements": ["shield_glow", "dark_receding"], "backgroundGradient": ["#1a1a2e", "#050508"], "particleConfig": { "type": "shield_particles", "count": 60, "color": "#4488ff", "speed": "slow", "direction": "outward" }, "motionType": "pulse", "ambientColor": "#050508", "glowColor": "#4488ff", "transitionDuration": 3000, "reflectionPrompt": "Truth is protected from the whispers of the rejected.", "tafsirHighlight": "And it (the Quran) is not the word of an outcast Satan." },
    { "verseNumber": 26, "verseKey": "81:26", "emotion": "warning", "atmosphere": "clarity", "visualElements": ["directional_arrows", "lost_path"], "backgroundGradient": ["#050508", "#3d0000"], "particleConfig": { "type": "confusion", "count": 40, "color": "#ff0000", "speed": "fast", "direction": "random" }, "motionType": "agitate", "ambientColor": "#1a0000", "glowColor": "#ff0000", "transitionDuration": 2000, "reflectionPrompt": "So where are you going?", "tafsirHighlight": "So where then are you going? A profound question for every soul." },
    { "verseNumber": 27, "verseKey": "81:27", "emotion": "solemn", "atmosphere": "universal", "visualElements": ["world_glow", "universal_message"], "backgroundGradient": ["#3d0000", "#1a1a2e"], "particleConfig": { "type": "global_orbs", "count": 100, "color": "#ffffff", "speed": "very_slow", "direction": "outward" }, "motionType": "expand", "ambientColor": "#1a1a2e", "glowColor": "#ffffff", "transitionDuration": 4000, "reflectionPrompt": "Is this Reminder for you, or just for the world?", "tafsirHighlight": "It is but a Reminder for all the worlds." },
    { "verseNumber": 28, "verseKey": "81:28", "emotion": "hope", "atmosphere": "choice", "visualElements": ["dual_path", "light_path"], "backgroundGradient": ["#1a1a2e", "#c9a84c"], "particleConfig": { "type": "path_markers", "count": 20, "color": "#ffffff", "speed": "slow", "direction": "forward" }, "motionType": "drift", "ambientColor": "#c9a84c", "glowColor": "#ffffff", "transitionDuration": 3000, "reflectionPrompt": "Do you will to stand straight today?", "tafsirHighlight": "To whomsoever among you wills to stand straight." },
    { "verseNumber": 29, "verseKey": "81:29", "emotion": "awe", "atmosphere": "divine", "visualElements": ["divine_will_glow", "absolute_radiance"], "backgroundGradient": ["#c9a84c", "#ffffff", "#000000"], "particleConfig": { "type": "will_waves", "count": 5, "color": "#ffffff", "speed": "very_slow", "direction": "outward" }, "motionType": "expand", "ambientColor": "#000000", "glowColor": "#ffffff", "transitionDuration": 5000, "reflectionPrompt": "Our will is within His Will. How does that feel?", "tafsirHighlight": "And you do not will except that Allah wills — the Lord of all the worlds." }
  ]
}
