{
  "surahNumber": 88,
  "surahName": "Al-Ghashiyah",
  "scenes": [
    { "verseNumber": 1, "verseKey": "88:1", "emotion": "warning", "atmosphere": "overwhelming", "visualElements": ["dark_cloud", "approaching_force"], "backgroundGradient": ["#050508", "#1a0000"], "particleConfig": { "type": "mist", "count": 100, "color": "#1a0000", "speed": "slow", "direction": "forward" }, "motionType": "expand", "ambientColor": "#050508", "glowColor": "#ff0000", "transitionDuration": 3000, "reflectionPrompt": "Have you heard the news that will overwhelm everything?", "tafsirHighlight": "The Overwhelming (Al-Ghashiyah) is the Day of Resurrection, which will cover everyone with its terror." },
    { "verseNumber": 2, "verseKey": "88:2", "emotion": "dread", "atmosphere": "humbled", "visualElements": ["lowered_eyes", "shadowy_figures"], "backgroundGradient": ["#1a0000", "#0a0a0a"], "particleConfig": { "type": "dust", "count": 50, "color": "#000000", "speed": "very_slow", "direction": "downward" }, "motionType": "sink", "ambientColor": "#000000", "glowColor": "#ff4500", "transitionDuration": 2500, "reflectionPrompt": "When the Truth is seen, arrogance disappears. What is left?", "tafsirHighlight": "On that Day, some faces will be downcast, humbled by shame and terror." },
    { "verseNumber": 3, "verseKey": "88:3", "emotion": "warning", "atmosphere": "exhausted", "visualElements": ["heavy_labor", "fading_energy"], "backgroundGradient": ["#0a0a0a", "#1a1000"], "particleConfig": { "type": "sweat", "count": 30, "color": "#8b4513", "speed": "slow", "direction": "downward" }, "motionType": "tremor", "ambientColor": "#0a0a00", "glowColor": "#8b4513", "transitionDuration": 2000, "reflectionPrompt": "Laboring without purpose leads to exhaustion. What are we working for?", "tafsirHighlight": "They labored and exhausted themselves in this world, but for the wrong purpose." },
    { "verseNumber": 4, "verseKey": "88:4", "emotion": "warning", "atmosphere": "inferno", "visualElements": ["intense_heat", "red_glow"], "backgroundGradient": ["#1a1000", "#3d0000"], "particleConfig": { "type": "fire", "count": 150, "color": "#ff0000", "speed": "fast", "direction": "upward" }, "motionType": "surge", "ambientColor": "#1a0000", "glowColor": "#ff0000", "transitionDuration": 1500, "reflectionPrompt": "Heat that never ends. How do we find cool water today?", "tafsirHighlight": "They will enter and burn in an intensely hot Fire." },
    { "verseNumber": 5, "verseKey": "88:5", "emotion": "warning", "atmosphere": "inferno", "visualElements": ["boiling_spring", "steam"], "backgroundGradient": ["#3d0000", "#1a0000"], "particleConfig": { "type": "steam", "count": 80, "color": "#ff4500", "speed": "fast", "direction": "upward" }, "motionType": "surge", "ambientColor": "#000000", "glowColor": "#ff4500", "transitionDuration": 1500, "reflectionPrompt": "Thirst that cannot be quenched. What are we truly thirsty for?", "tafsirHighlight": "They will be given to drink from a boiling spring." },
    { "verseNumber": 6, "verseKey": "88:6", "emotion": "warning", "atmosphere": "bitter", "visualElements": ["thorns", "dark_organic_shapes"], "backgroundGradient": ["#1a0000", "#0a0a0a"], "particleConfig": { "type": "thorns", "count": 40, "color": "#000000", "speed": "still", "direction": "none" }, "motionType": "agitate", "ambientColor": "#050000", "glowColor": "#ff0000", "transitionDuration": 2000, "reflectionPrompt": "Bitter food for a bitter heart. How do we sweeten our souls?", "tafsirHighlight": "No food will be for them except from a bitter, thorny plant." },
    { "verseNumber": 7, "verseKey": "88:7", "emotion": "warning", "atmosphere": "bitter", "visualElements": ["hollow_shapes", "starvation_shadows"], "backgroundGradient": ["#0a0a0a", "#1a0000"], "particleConfig": { "type": "hollow", "count": 20, "color": "#3d0000", "speed": "slow", "direction": "downward" }, "motionType": "sink", "ambientColor": "#000000", "glowColor": "#3d0000", "transitionDuration": 2500, "reflectionPrompt": "Nourishment that does not nourish. What are we consuming?", "tafsirHighlight": "It neither nourishes nor satisfies their hunger." },
    { "verseNumber": 8, "verseKey": "88:8", "emotion": "hope", "atmosphere": "joyful", "visualElements": ["bright_faces", "radiant_glow"], "backgroundGradient": ["#050508", "#002a00"], "particleConfig": { "type": "gold_dust", "count": 100, "color": "#c9a84c", "speed": "slow", "direction": "upward" }, "motionType": "bloom", "ambientColor": "#001a00", "glowColor": "#c9a84c", "transitionDuration": 3000, "reflectionPrompt": "Faces radiant with joy. Is this the goal you see?", "tafsirHighlight": "On that Day, other faces will be joyful and radiant." },
    { "verseNumber": 9, "verseKey": "88:9", "emotion": "hope", "atmosphere": "satisfied", "visualElements": ["light_path", "fulfilled_forms"], "backgroundGradient": ["#002a00", "#004d00"], "particleConfig": { "type": "light_orbs", "count": 50, "color": "#ffffff", "speed": "slow", "direction": "forward" }, "motionType": "drift", "ambientColor": "#002a00", "glowColor": "#ffffff", "transitionDuration": 3500, "reflectionPrompt": "Effort that leads to satisfaction. What are you striving for?", "tafsirHighlight": "Well-pleased with their efforts in the world." },
    { "verseNumber": 10, "verseKey": "88:10", "emotion": "hope", "atmosphere": "elevated", "visualElements": ["high_garden", "vast_horizon"], "backgroundGradient": ["#004d00", "#006600", "#4488ff"], "particleConfig": { "type": "petals", "count": 60, "color": "#ffffff", "speed": "very_slow", "direction": "downward" }, "motionType": "expand", "ambientColor": "#004d00", "glowColor": "#ffffff", "transitionDuration": 4000, "reflectionPrompt": "An elevated Garden. How high are your aspirations?", "tafsirHighlight": "In a high Garden (Paradise)." },
    { "verseNumber": 11, "verseKey": "88:11", "emotion": "hope", "atmosphere": "peaceful", "visualElements": ["silent_breeze", "soft_textures"], "backgroundGradient": ["#4488ff", "#ffffff"], "particleConfig": { "type": "soft_mist", "count": 20, "color": "#ffffff", "speed": "very_slow", "direction": "horizontal" }, "motionType": "breathe", "ambientColor": "#ffffff", "glowColor": "#4488ff", "transitionDuration": 5000, "reflectionPrompt": "Peace without idle talk. What would you do in such a place?", "tafsirHighlight": "They will not hear therein any idle or harmful speech." },
    { "verseNumber": 12, "verseKey": "88:12", "emotion": "hope", "atmosphere": "flowing", "visualElements": ["running_spring", "sparkling_water"], "backgroundGradient": ["#ffffff", "#4488ff"], "particleConfig": { "type": "water_droplets", "count": 80, "color": "#ffffff", "speed": "medium", "direction": "downward" }, "motionType": "surge", "ambientColor": "#4488ff", "glowColor": "#ffffff", "transitionDuration": 3000, "reflectionPrompt": "A spring that always flows. What is the source of your peace?", "tafsirHighlight": "Therein is a flowing spring." },
    { "verseNumber": 13, "verseKey": "88:13", "emotion": "hope", "atmosphere": "honored", "visualElements": ["elevated_throne", "gold_textures"], "backgroundGradient": ["#4488ff", "#c9a84c"], "particleConfig": { "type": "gold_shimmer", "count": 40, "color": "#c9a84c", "speed": "slow", "direction": "upward" }, "motionType": "rise", "ambientColor": "#c9a84c", "glowColor": "#ffffff", "transitionDuration": 3500, "reflectionPrompt": "Raised couches of honor. How do you honor yourself today?", "tafsirHighlight": "Therein are couches raised high." },
    { "verseNumber": 14, "verseKey": "88:14", "emotion": "hope", "atmosphere": "prepared", "visualElements": ["crystal_cups", "sparkling_light"], "backgroundGradient": ["#c9a84c", "#ffffff"], "particleConfig": { "type": "sparkles", "count": 100, "color": "#ffffff", "speed": "slow", "direction": "center" }, "motionType": "still", "ambientColor": "#ffffff", "glowColor": "#c9a84c", "transitionDuration": 2500, "reflectionPrompt": "Everything is prepared for you. Do you feel welcomed?", "tafsirHighlight": "And cups set in place for drinking." },
    { "verseNumber": 15, "verseKey": "88:15", "emotion": "hope", "atmosphere": "comfort", "visualElements": ["soft_cushions", "patterned_light"], "backgroundGradient": ["#ffffff", "#f0ead6"], "particleConfig": { "type": "soft_glow", "count": 30, "color": "#f0ead6", "speed": "very_slow", "direction": "pulse" }, "motionType": "breathe", "ambientColor": "#f0ead6", "glowColor": "#c9a84c", "transitionDuration": 3000, "reflectionPrompt": "Comfort that lasts. Where is your place of rest?", "tafsirHighlight": "And cushions arrayed in order." },
    { "verseNumber": 16, "verseKey": "88:16", "emotion": "hope", "atmosphere": "rich", "visualElements": ["lush_carpets", "rich_textures"], "backgroundGradient": ["#f0ead6", "#002a00"], "particleConfig": { "type": "fiber_glow", "count": 50, "color": "#00ff00", "speed": "slow", "direction": "spread" }, "motionType": "expand", "ambientColor": "#002a00", "glowColor": "#ffffff", "transitionDuration": 4000, "reflectionPrompt": "Carpets spread out. How do you beautify your path?", "tafsirHighlight": "And rich carpets spread out everywhere." },
    { "verseNumber": 17, "verseKey": "88:17", "emotion": "solemn", "atmosphere": "reflective", "visualElements": ["camel_silhouette", "desert_horizon"], "backgroundGradient": ["#002a00", "#1a1000"], "particleConfig": { "type": "sand", "count": 20, "color": "#c9a84c", "speed": "slow", "direction": "horizontal" }, "motionType": "drift", "ambientColor": "#1a1000", "glowColor": "#c9a84c", "transitionDuration": 3000, "reflectionPrompt": "Do they not look at the camel? What complexity do you see in the mundane?", "tafsirHighlight": "Allah invites us to reflect on the camel — a masterpiece of adaptation and creation." },
    { "verseNumber": 18, "verseKey": "88:18", "emotion": "solemn", "atmosphere": "reflective", "visualElements": ["upward_view", "vast_sky"], "backgroundGradient": ["#1a1000", "#1a1a2e", "#4488ff"], "particleConfig": { "type": "sky_glow", "count": 0, "color": "#ffffff", "speed": "still", "direction": "none" }, "motionType": "expand", "ambientColor": "#4488ff", "glowColor": "#ffffff", "transitionDuration": 4000, "reflectionPrompt": "The sky raised high. What is beyond your reach?", "tafsirHighlight": "Reflect on the heaven and how it was raised without pillars." },
    { "verseNumber": 19, "verseKey": "88:19", "emotion": "solemn", "atmosphere": "reflective", "visualElements": ["mountain_peak", "rocky_textures"], "backgroundGradient": ["#4488ff", "#0a0a0a"], "particleConfig": { "type": "rock_dust", "count": 30, "color": "#8a8a9a", "speed": "slow", "direction": "downward" }, "motionType": "still", "ambientColor": "#000000", "glowColor": "#8a8a9a", "transitionDuration": 3500, "reflectionPrompt": "Mountains set firm. What are the pillars of your faith?", "tafsirHighlight": "Reflect on the mountains and how they were firmly set." },
    { "verseNumber": 20, "verseKey": "88:20", "emotion": "solemn", "atmosphere": "reflective", "visualElements": ["spread_earth", "level_path"], "backgroundGradient": ["#0a0a0a", "#1a1000"], "particleConfig": { "type": "dust", "count": 40, "color": "#8b4513", "speed": "slow", "direction": "horizontal" }, "motionType": "drift", "ambientColor": "#1a1000", "glowColor": "#8b4513", "transitionDuration": 4000, "reflectionPrompt": "The earth spread out. How will you use this space?", "tafsirHighlight": "Reflect on the earth and how it was spread out for your benefit." },
    { "verseNumber": 21, "verseKey": "88:21", "emotion": "solemn", "atmosphere": "reminding", "visualElements": ["pulse_center", "clear_light"], "backgroundGradient": ["#1a1000", "#ffffff"], "particleConfig": { "type": "pulse", "count": 1, "color": "#000000", "speed": "slow", "direction": "center" }, "motionType": "focus", "ambientColor": "#ffffff", "glowColor": "#000000", "transitionDuration": 2500, "reflectionPrompt": "You are only a reminder. Who are you reminding today?", "tafsirHighlight": "So remind, [O Muhammad]; you are only a reminder." },
    { "verseNumber": 22, "verseKey": "88:22", "emotion": "solemn", "atmosphere": "freedom", "visualElements": ["open_horizon", "no_chains"], "backgroundGradient": ["#ffffff", "#4488ff"], "particleConfig": { "type": "freedom_orbs", "count": 30, "color": "#4488ff", "speed": "slow", "direction": "outward" }, "motionType": "expand", "ambientColor": "#4488ff", "glowColor": "#ffffff", "transitionDuration": 3500, "reflectionPrompt": "You have no control over their hearts. Does that bring you peace?", "tafsirHighlight": "You are not a dictator or controller over them." },
    { "verseNumber": 23, "verseKey": "88:23", "emotion": "warning", "atmosphere": "rejection", "visualElements": ["receding_light", "dark_wall"], "backgroundGradient": ["#4488ff", "#050508"], "particleConfig": { "type": "rejection", "count": 20, "color": "#3d0000", "speed": "fast", "direction": "backward" }, "motionType": "sink", "ambientColor": "#050508", "glowColor": "#3d0000", "transitionDuration": 2500, "reflectionPrompt": "To turn away is a choice. Where are we turning?", "tafsirHighlight": "But whoever turns away and disbelieves..." },
    { "verseNumber": 24, "verseKey": "88:24", "emotion": "warning", "atmosphere": "judgment", "visualElements": ["intense_dark_red", "final_force"], "backgroundGradient": ["#050508", "#3d0000"], "particleConfig": { "type": "final_sparks", "count": 60, "color": "#ff0000", "speed": "fast", "direction": "upward" }, "motionType": "surge", "ambientColor": "#1a0000", "glowColor": "#ff0000", "transitionDuration": 2000, "reflectionPrompt": "The greatest punishment. How do we seek the greatest mercy?", "tafsirHighlight": "Allah will punish them with the greatest punishment." },
    { "verseNumber": 25, "verseKey": "88:25", "emotion": "awe", "atmosphere": "return", "visualElements": ["directional_waves", "center_pull"], "backgroundGradient": ["#3d0000", "#000000"], "particleConfig": { "type": "return_orbs", "count": 100, "color": "#ffffff", "speed": "slow", "direction": "inward" }, "motionType": "collapse", "ambientColor": "#000000", "glowColor": "#ffffff", "transitionDuration": 4000, "reflectionPrompt": "To Him is our return. Are we ready to go back?", "tafsirHighlight": "Indeed, to Us is their return." },
    { "verseNumber": 26, "verseKey": "88:26", "emotion": "solemn", "atmosphere": "accountability", "visualElements": ["final_focus", "still_void"], "backgroundGradient": ["#000000", "#050508"], "particleConfig": { "type": "still_light", "count": 1, "color": "#ffffff", "speed": "very_slow", "direction": "center" }, "motionType": "still", "ambientColor": "#050508", "glowColor": "#ffffff", "transitionDuration": 5000, "reflectionPrompt": "The account is with Him. What is your final thought?", "tafsirHighlight": "Then indeed, upon Us is their account." }
  ]
}
