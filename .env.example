# Quran Foundation Content API Credentials
VITE_QF_CLIENT_ID=your_client_id_here
VITE_QF_CLIENT_SECRET=your_client_secret_here

# Quran Foundation OAuth Redirect (for User APIs)
VITE_QF_REDIRECT_URI=http://localhost:5173/auth/callback

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Default API Settings
VITE_DEFAULT_TRANSLATION_ID=131
VITE_DEFAULT_TAFSIR_ID=169
VITE_DEFAULT_RECITER_ID=7
